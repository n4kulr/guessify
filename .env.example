# --- Local dev with `vercel dev` (or set these in the Vercel dashboard for prod) ---

# From https://developer.spotify.com/dashboard  (create an app — library/OAuth only)
# Audio previews come from the free iTunes Search API (no Apple key).
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Last.fm API key for Charts & vibes (tag top tracks). Free at https://www.last.fm/api/account/create
# Only the public key is needed — no secret / user login.
LASTFM_API_KEY=your_lastfm_api_key_here

# Any long random string — used to encrypt the login cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string

# Multiplayer (Cloudflare Workers / PartyServer).
# Local default is 127.0.0.1:8787 when running `npm run dev:party`.
# After `npm run deploy:party`, set this to your workers.dev host (no https://) and redeploy Vercel.
# VITE_PARTYKIT_HOST=guessify.your-subdomain.workers.dev

# Discord channel webhook for the in-app feedback button (Server Settings → Integrations → Webhooks).
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
