# Get these from https://developer.spotify.com/dashboard
# 1. Create an app.
# 2. In the app settings, add this Redirect URI EXACTLY:
#      http://127.0.0.1:8888/api/callback
#    (Spotify no longer allows "localhost" — you must use 127.0.0.1)
# 3. Copy the Client ID and Client Secret below.
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Must match the Redirect URI registered in the dashboard.
REDIRECT_URI=http://127.0.0.1:8888/api/callback

# Where the frontend runs (users get sent back here after login).
FRONTEND_URL=http://127.0.0.1:5173

# Port the backend runs on.
PORT=8888
